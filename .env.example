# Default (no file): UI uses https://api.sockethr.com via public/runtime-config.json — same as production.
#
# Local API only (no tunnel): point UI at your machine
# VITE_SOCKETHR_API_BASE=http://127.0.0.1:3000
#
# Production build: see .env.production.example or:
# VITE_SOCKETHR_API_BASE=https://api.sockethr.com npm run build
#
# Public deploy + tunnel: docs/PUBLIC_TUNNEL.md
