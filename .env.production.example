# Used automatically by `npm run build` (Vite production mode).
# Copy to .env.production and set your tunnel URL (HTTPS, no trailing slash).
#
# Alternatively, leave this unset and set apiBase in public/runtime-config.json
# (or edit dist/runtime-config.json after build) so you can change the API URL without rebuilding.

VITE_SOCKETHR_API_BASE=https://api.sockethr.com
