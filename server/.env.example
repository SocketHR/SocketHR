# LM Studio: Developer tab → Start server (default port 1234)
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# Exact id from GET http://127.0.0.1:1234/v1/models in LM Studio
LM_STUDIO_MODEL=openai/gpt-oss-20b

PORT=3000
HOST=0.0.0.0

# Optional: where job folders are written (default: ../data/jobs from server/)
# SOCKETHR_DATA_DIR=/path/to/data/jobs

# Advertising waitlist → email via SMTP (e.g. Gmail App Password: Google Account → Security → 2-Step Verification → App passwords)
# WAITLIST_SMTP_HOST=smtp.gmail.com
# WAITLIST_SMTP_PORT=587
# WAITLIST_SMTP_USER=youraccount@gmail.com
# WAITLIST_SMTP_PASS=xxxx xxxx xxxx xxxx
# WAITLIST_MAIL_FROM=youraccount@gmail.com
# WAITLIST_MAIL_TO=contact@sockethr.com
# WAITLIST_BRAND_NAME=SocketHR
# WAITLIST_TEAM_NAME=The SocketHR Team
