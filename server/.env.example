# LM Studio: Developer tab → Start server (default port 1234)
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# Exact id from GET http://127.0.0.1:1234/v1/models in LM Studio
LM_STUDIO_MODEL=openai/gpt-oss-20b

PORT=3000
HOST=0.0.0.0

# Optional: where job folders are written (default: ../data/jobs from server/)
# SOCKETHR_DATA_DIR=/path/to/data/jobs
